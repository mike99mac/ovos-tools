#!/bin/bash
#
# install1 - configure a new Linux for a Minimy or OVOS installation
#
#+--------------------------------------------------------------------------+
function usage
# Give help to the user
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  echo "install1 - configure Linux for Minimy, Neon or OVOS"
  echo "Usage: install1 [OPTIONS]" 
  echo ""
  echo "OPTIONS:"
  echo "  -h|--help         Give help (this screen)"
  echo "  -m|--minimy       Configure for Minimy (default)"
  echo "  -n|--neon         Configure for Neon"
  echo "  -o|--ovos         Configure for OVOS"
  echo "  -v|--verbose      Increase verbosity"
  echo "  -x|--debug        Print commands and arguments as they are executed"
  echo ""
  exit 51
}

#+--------------------------------------------------------------------------+
function parseArgs
# Parse arguments
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  while [ -n "$1" ]; do
    case "$1" in
      -h|--help)
        usage
        ;;
      -v|--verbose)
        verbose=2
        flags="-v"
        ;;
      -x|--debug)
        set -vx
        ;;
      *)
        echo "ERROR: Too many arguments: $1"
        usage
        ;;
    esac
    shift
  done
 }

#+--------------------------------------------------------------------------+
function getPlatform
# Set platform to either "Raspberry Pi" or "NVIDIA Jetson" else warn
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  platform=$(cat /proc/device-tree/model | awk '{print $1 " " $2}')
  if [ "$platform" != "Raspberry Pi" ] && [ "$platform" != "NVIDIA Jetson" ]; then
    echo "WARNING: Only Nvidia Jetson and Raspberry Pi platforms are supported."
  fi
 }

#+--------------------------------------------------------------------------+
function checkOvosTools
# Check that ovos-tools is installed in $HOME
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  baseDir="$HOME/ovos-tools"
  if [ ! -d "$baseDir" ]; then
    echo "ERROR: Did not find ovos-tools in $baseDir"
    exit 1
  fi
 }

#+--------------------------------------------------------------------------+
function runCmd
# run a command, report time spent and exit if it fails
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  cmd="$@"
  echo " " 
  echo "Running: $cmd" | tee -a "$outFile"
  eval "$cmd" 2>&1 | tee -a "$outFile"
  rc=$?
  if [ "$rc" != 0 ]; then
    echo "ERROR: $cmd returned $rc - EXITING!!!" 
    exit 1
  else
    echo "Command was successful!" 
  fi
 }

#+--------------------------------------------------------------------------+
function configMpd
# Set mpd service to start at boot time (user service)
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  local mpd_conf_dir="$HOME/.config/mpd"
  local mpd_data_dir="$HOME/.local/share/mpd"
  local mpd_cache_dir="$HOME/.cache/mpd"
  local mpd_log_dir="$HOME/.local/share/mpd"
  local mpd_conf_file="$mpd_conf_dir/mpd.conf"

  echo "Configuring MPD as a user service..." | tee -a "$outFile"

  # create directories
  mkdir -p "$mpd_conf_dir" "$mpd_data_dir/playlists" "$mpd_cache_dir" "$mpd_log_dir"

  # create minimal mpd.conf (no comments, pipewire-pulse output)
  cat > "$mpd_conf_file" << EOF
auto_update "yes"
bind_to_address "127.0.0.1"
db_file "$mpd_cache_dir/tag_cache"
log_file "$mpd_log_dir/mpd.log"
log_level "default"
music_directory "/mnt/share/music"
playlist_directory "$mpd_data_dir/playlists"
state_file "$mpd_data_dir/state"
sticker_file "$mpd_data_dir/sticker.sql"
follow_outside_symlinks "yes"
follow_inside_symlinks "yes"
filesystem_charset "UTF-8"
zeroconf_enabled "no"

audio_output {
  type "pulse"
  name "PipeWire Pulse"
  server "/run/user/$UID/pulse/native"
  mixer_type "software"
}
EOF

  # stop and disable system mpd if running
  sudo systemctl stop mpd 2>/dev/null
  sudo systemctl disable mpd 2>/dev/null

  # create user service file if missing
  if ! systemctl --user list-unit-files | grep -q mpd.service; then
    mkdir -p "$HOME/.config/systemd/user"
    cat > "$HOME/.config/systemd/user/mpd.service" << EOF
[Unit]
Description=Music Player Daemon
After=network.target pipewire-pulse.service

[Service]
ExecStart=/usr/bin/mpd --no-daemon $mpd_conf_file
Restart=on-failure

[Install]
WantedBy=default.target
EOF
  fi

  systemctl --user daemon-reload
  systemctl --user enable mpd
  systemctl --user start mpd

  echo "MPD user service enabled and started." | tee -a "$outFile"
 }

#+--------------------------------------------------------------------------+
function installCoreqs
# Do the work to install and configure everything to run Mycroft driven by ovos-core
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  if [ -z "$USER" ]; then
    echo "WARNING! environment variable USER is not set - setting to 'pi'"
    USER=pi
  fi

  echo "Upgrading system ..." | tee -a "$outFile"
  runCmd sudo apt-get update
  runCmd sudo apt-get -y -o Dpkg::Options::="--force-confdef" full-upgrade 

  distro=$(grep ^PRETTY /etc/os-release | awk -F'"' '{print $2}')
  if [ -z "$distro" ]; then
    echo "ERROR: did not find PRETTY_NAME in /etc/os-release" 
    exit 1
  fi
  echo "distro = $distro"

  echo "Installing co-req packages ..." | tee -a "$outFile"
  pyVer=$(python3 -V | awk '{print $2}' | awk -F. '{print $1 "." $2}')
  runCmd sudo apt-get --quiet install -y "bind9-dnsutils cifs-utils curl jq plocate lsof mpc mpd net-tools pandoc python3 python3-pip python3-venv python${pyVer}-venv pipewire pipewire-audio-client-libraries pipewire-pulse wireplumber"
  runCmd sudo updatedb

  if [ "$platform" = "NVIDIA Jetson" ]; then
    runCmd sudo apt-get --quiet install -y liblgpio-dev
  else
    runCmd sudo apt-get --quiet install -y python3-rpi.gpio raspi-config
  fi

  if [ ! -f /etc/vim/vimrc.orig ]; then
    runCmd sudo cp /etc/vim/vimrc /etc/vim/vimrc.orig
  fi    
  echo "Copying vimrc ..." | tee -a "$outFile"
  runCmd sudo cp "$HOME/ovos-tools/vimrc" /etc/vim
  echo
  configMpd
  echo "Adding groups to user $USER ..." | tee -a "$outFile"
  runCmd sudo usermod -a -G audio,video,dialout,kmem "$USER"
  echo "Adding groups spi, i2c and gpio to /etc/group ..." | tee -a "$outFile"
  sudo groupadd -g 993 spi 2>/dev/null | tee -a "$outFile"
  sudo groupadd -g 994 i2c 2>/dev/null | tee -a "$outFile"
  sudo groupadd -g 993 gpio 2>/dev/null | tee -a "$outFile"
  echo
  echo "Copying .bash_profile ..." | tee -a "$outFile"
  runCmd cp "$HOME/ovos-tools/minimy_profile" "$HOME/.bash_profile"
  
  # turn default and vc4 audio off, don't disable monitor overscan
  cd /boot/firmware || cd /boot
  if [ ! -f config.txt.orig ]; then
    echo "Customizing boot parameters ..." | tee -a "$outFile"
    runCmd sudo cp config.txt config.txt.orig
    sudo sed -i -e 's/dtparam=audio=on/dtparam=audio=off\ndtparam=spi=off/g' \
                -e 's/^disable_overscan/# disable_overscan/g' \
                -e 's/^dtoverlay=vc4-kms-v3/# dtoverlay=vc4-kms-v3/g' config.txt
    local piModel=$(cat /sys/firmware/devicetree/base/model | awk '{print $3}')
    if [ "$piModel" = "5" ]; then
      echo "dtoverlay=vc4-kms-v3d,noaudio" | sudo tee -a config.txt
      echo "dtoverlay=hifiberry-dacplus,slave" | sudo tee -a config.txt
      echo "force_eeprom_read=0" | sudo tee -a config.txt
    else
      echo "dtoverlay=hifiberry-dacplus-pro" | sudo tee -a config.txt
    fi
  fi  
  
  # vim - traditional defaults, mouse works
  echo "Removing annoying autoindent from vim ..." | tee -a "$outFile"
  if [ ! -d "$HOME/.vim" ]; then
    runCmd mkdir "$HOME/.vim"
    cd "$HOME/.vim" || return
    {
      echo "set noautoindent"
      echo "set nocindent"
      echo "set nosmartindent"
      echo "set mouse=r"
    } >> vimrc
  fi  

  if [ "$platform" = "Raspberry Pi" ]; then
    echo "Setting pipewire and pipewire-pulse to start at boot time..." | tee -a "$outFile"
    runCmd systemctl --user enable pipewire pipewire-pulse
  fi
  echo "Disabling bluetooth ..." | tee -a "$outFile"
  runCmd sudo systemctl disable bluetooth.service

  # configure USB hot plug to mount USB drive over /mnt/usb
  runCmd sudo cp ~/ovos-tools/99-mount-usb.rules /etc/udev/rules.d
  runCmd sudo cp ~/ovos-tools/usb-mount@.service /etc/systemd/system
  runCmd sudo cp ~/ovos-tools/usb-mount.sh /root

  # configure network drive to mount over /mnt/share
  first3=$(hostname -I | awk '{print $1}' | awk -F. '{print $1 "." $2 "." $3}')
  if [ "$first3" = "192.168.40" ]; then
    echo "Configuring network drive to mount over /mnt/share ..." | tee -a "$outFile"
    if [ ! -f /etc/fstab.orig ]; then
      sudo cp /etc/fstab /etc/fstab.orig
      echo "//LS210D7A7.lan/share   /mnt/share    cifs    user=mike,password=sawdust5,vers=1.0 0 0" | sudo tee -a /etc/fstab
    fi
  fi
  if [ ! -d /mnt/share ]; then
    sudo mkdir /mnt/share
    sudo chgrp users /mnt/share
    sudo chmod 777 /mnt/share
  fi
  grep "/mnt/share" /etc/mtab >/dev/null 2>&1
  if [ $? != 0 ]; then
    runCmd sudo mount /mnt/share
  fi
 }

# global variables
timeStamp=$(date +"%y-%m-%d-%H-%M-%S")   
outFile="$HOME/$timeStamp-install1.out"
platform="unknown"

# main()
getPlatform
parseArgs "$@"
checkOvosTools
echo "Running install1 on $timeStamp to configure minimy ..." > "$outFile"
installCoreqs
let min=$SECONDS/60
let sec=$SECONDS%60
if [ $sec -lt 10 ]; then
  sec="0$sec"
fi
echo "Successfully installed co-reqs for minimy in $min:$sec" | tee -a "$outFile"
echo "Log file: $outFile"
