#!/bin/bash
#
# sortlogs - merge and sort all log files
#
logDir="$HOME/minimy/logs"
if [ ! -d $logDir ]; then                  # log directory not found
  echo "Log directory $logDir does not exist"
  exit 1
fi
cd $logDir
ls *.log >/dev/null 2>&1
if [ $? != 0 ]; then                       # no log files found
  echo "No log files found in $logDir"
  exit 2
fi
timeStamp=`date +"%y-%m-%d-%H-%M-%S"`
sortedFile="$HOME/$timeStamp-minimy.logs"
unsortedFile="$HOME/$timeStamp-unsorted.logs"
for i in *.log; do                         # copy all log files
  cat $i >> $unsortedFile
done
sort $unsortedFile > $sortedFile                   # sort by timestamp
echo "sorted logs saved to: $sortedFile and $unsortedFile"

