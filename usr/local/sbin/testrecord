#!/bin/bash
#
# testrecord - test recording with default or specified microphone or just list info
#
#+--------------------------------------------------------------------------+
function usage
# Give help to the user
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  echo "testrecord - test recording with default microphone"
  echo "Usage: testrecord [OPTIONS]" 
  echo ""
  echo "OPTIONS:"
  echo "  -c|--cardnum CARD Card number to use - needed when there are multiple microphones"
  echo "  -h|--help         Give help (this screen)"
  echo "  -l|--list         Just list microphone info - do not record"
  echo "  -v|--verbose      Increase verbosity" 
  echo "  -x|--debug        Print commands and arguments as they are executed"
  exit 51
 }                                         # usage()

#+--------------------------------------------------------------------------+
function parseArgs
# Parse arguments
# Args: All arguments passed into script
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  while [ -n "$1" ]                        # loop through args passed in
  do
    case "$1" in
      -c|--cardnum)
        if [ $# = 0 ]; then                # CARD not passed in
          echo "ERROR! CARD not passed in after $1"
          usage                            # give help
        fi
        shift                              # get to next arg
        cardToUse=$1
        ;;
      -h|--help)
        usage
        ;;
      -l|--list)
        actionType="list"
        ;;
      -v|--verbose) 
        verbose=2
        flags="-v"
        ;;
      -x|--debug)                          # turn trace on
         set -vx
         ;;
      *)
	echo "ERROR: Too many arguments: $1"
	usage 
        ;;
    esac
    shift
  done
 }                                         # parseArgs()

#+--------------------------------------------------------------------------+
function getSupportedFormat
# Get the best supported format for a card
# Arg 1: card number
# Returns: format string (S16_LE, S24_3LE, etc)
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  local cardNum=$1
  local cardDir="/proc/asound/card$cardNum/pcm0c/sub0"
  
  # Try to get format from hw_params if available
  if [ -f "$cardDir/hw_params" ]; then
    local format=`grep "^format:" "$cardDir/hw_params" 2>/dev/null | awk '{print $2}'`
    if [ -n "$format" ]; then
      echo "$format"
      return
    fi
  fi
  
  # Test what formats actually work with arecord
  # S16_LE is most compatible
  if arecord -D hw:$cardNum,0 -r 44100 -c 1 -f S16_LE -d 0.1 /tmp/test-format-$cardNum.wav 2>/dev/null; then
    echo "S16_LE"
    rm -f /tmp/test-format-$cardNum.wav
    return
  fi
  
  # Default fallback
  echo "S16_LE"
 }                                         # getSupportedFormat()

#+--------------------------------------------------------------------------+
function testCardCapture
# Test if a card can actually capture audio
# Arg 1: card number
# Returns: 0 if it captures, 1 if silent
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  local cardNum=$1
  local testFile="/tmp/capture-test-$cardNum.wav"
  
  # Record 1 second of audio
  arecord -D hw:$cardNum,0 -r 44100 -c 1 -f S16_LE -d 1 "$testFile" 2>/dev/null
  
  # Check if file has meaningful audio data (not silent)
  # A silent 1-second S16_LE mono file at 44100Hz should be ~88KB
  # If much smaller, it's likely empty/failed
  local size=$(stat -f%z "$testFile" 2>/dev/null || stat -c%s "$testFile" 2>/dev/null || echo 0)
  
  # S16_LE mono at 44100Hz = 88200 bytes per second + 44 byte header = 88244 bytes
  # Allow some margin for compression
  if [ $size -gt 80000 ]; then
    if [ "$verbose" = 2 ]; then
      echo "Card $cardNum: captures audio (file size: $size bytes)"
    fi
    rm -f "$testFile"
    return 0
  else
    if [ "$verbose" = 2 ]; then
      echo "Card $cardNum: no audio captured (file size: $size bytes - likely silent)"
    fi
    rm -f "$testFile"
    return 1
  fi
 }                                         # testCardCapture()

#+--------------------------------------------------------------------------+
function findBestMicrophone
# Automatically select the best microphone from available options
# Returns: the best card number to use
# Priority: Actually captures audio > USB audio devices > other devices
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  local micCards=$1
  local bestCard=""
  local bestScore=0

  for card in $micCards; do
    local cardDir="/proc/asound/card$card/pcm0c/sub0"
    local score=0
    
    # Skip if card directory doesn't exist
    if [ ! -d "$cardDir" ]; then
      if [ "$verbose" = 2 ]; then
        echo "Card $card: SKIPPED (no pcm0c/sub0)"
      fi
      continue
    fi
    
    # Skip NVIDIA tegra/APE virtual devices
    if [ -f "$cardDir/info" ]; then
      if grep -q "tegra\|APE\|XBAR" "$cardDir/info" 2>/dev/null; then
        if [ "$verbose" = 2 ]; then
          echo "Card $card: SKIPPED (virtual device)"
        fi
        continue
      fi
    fi
    
    # TEST: Can this card actually capture audio?
    if testCardCapture $card; then
      score=$((score + 1000))  # Huge bonus for actually working
    else
      score=$((score + 100))   # Still score it, but lower
    fi
    
    # Check for USB device (preferred, score +50)
    if [ -f "$cardDir/info" ]; then
      if grep -q "USB" "$cardDir/info" 2>/dev/null; then
        score=$((score + 50))
      fi
    fi
    
    # Check for stereo (score +10)
    local channels=`grep channels: "$cardDir/hw_params" 2>/dev/null | awk '{print $2}'`
    if [ "$channels" -gt 1 ] 2>/dev/null; then
      score=$((score + 10))
    fi
    
    # Check for high sample rate (score +5)
    local rate=`grep rate: "$cardDir/hw_params" 2>/dev/null | awk '{print $2}'`
    if [ "$rate" -ge 48000 ] 2>/dev/null; then
      score=$((score + 5))
    fi
    
    if [ "$verbose" = 2 ]; then
      echo "Card $card: score=$score, channels=$channels, rate=$rate"
    fi
    
    # Update best card if this one scores higher
    if [ $score -gt $bestScore ]; then
      bestScore=$score
      bestCard=$card
    fi
  done
  
  echo "$bestCard"
 }                                         # findBestMicrophone()

#+--------------------------------------------------------------------------+
function recordCard
# Record audio from a specific card 
# Arg 1: card number
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  local cardNum=$1
  local cardDir="/proc/asound/card$cardNum/pcm0c/sub0"
  if [ ! -d $cardDir ]; then
    echo "Uh-oh! $cardDir is not a directory"
    exit 4
  fi

  # Get supported format for this card
  local format=$(getSupportedFormat $cardNum)
  
  # Get rate if available
  local rate=44100
  if [ -f "$cardDir/hw_params" ]; then
    local rateFromFile=`grep rate: "$cardDir/hw_params" | awk '{print $2}'`
    if [ -n "$rateFromFile" ]; then
      rate=$rateFromFile
    fi
  fi
  
  # Get channels if available, default to 1
  local channels=1
  if [ -f "$cardDir/hw_params" ]; then
    local channelsFromFile=`grep channels: "$cardDir/hw_params" | awk '{print $2}'`
    if [ -n "$channelsFromFile" ]; then
      channels=$channelsFromFile
    fi
  fi

  # Build arecord command using -D to specify device directly
  local cmd="arecord -D hw:$cardNum,0 -r $rate -c $channels -f $format -d $numSecs /tmp/test-mic.wav"
  echo "Testing your microphone for $numSecs seconds ==========> SAY SOMETHING!"
  echo "INFO: running command: $cmd"
  $cmd                                     # run the command
  rc=$?
  if [ "$rc" != 0 ]; then                  # something didn't work
    echo "ERROR: command $cmd failed with $rc"
    exit $rc                               # not successful
  fi
 }                                         # recordCard()

#+--------------------------------------------------------------------------+
function listCard
# List attributes of a specific card
# Arg 1: card number
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  local cardNum=$1

  local cardDir="/proc/asound/card$cardNum/pcm0c/sub0"
  if [ ! -d "$cardDir" ]; then
    echo "Card $cardNum: directory not found"
    return
  fi
  
  echo "-------------------------------"
  echo "Microphone number $cardNum:"
  
  if [ -f "$cardDir/info" ]; then
    echo "Information:"
    cat $cardDir/info                      # show contents of file
  fi
  
  if [ -f "$cardDir/status" ]; then
    echo -n "Status: "
    cat $cardDir/status                    # show status file 
  fi
  
  if [ -f "$cardDir/hw_params" ]; then
    echo -n "hw_params: "
    cat $cardDir/hw_params                 # show hw_params file 
  fi
 }                                         # listCard()

#+--------------------------------------------------------------------------+
function performAction
# test recording with specific microphone or list info
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  # get fully qualified command
  local arecordCmd=`which arecord`
  if [ ${#arecordCmd} = 0 ]; then          # arecord not found
    echo "Uh-oh! the arecord command is not found - is alsa-utils installed?"
    return 4
  fi
  
  # get get mic(s) card number(s) and the number of mics found 
  local micCards=`$arecordCmd -l | grep ^card | awk '{print $2}' | sed 's/://g' | sort -u | xargs`
  local micCount=`echo $micCards | wc -w`

  # actions for 0, 1 or multiple cards found 
  case $micCount in
    0)                                     # no cards found
      echo "Uh-Oh!  did not find any microphones - output of $arecordCmd -l:"
      $arecordCmd -l
      ;;
    1) 
      if [ "$actionType" = record ]; then 
        if [ "$cardToUse" = default ]; then # card not passed in
          cardToUse=$micCards
        fi
        recordCard $cardToUse 
      else                                 # assume list
        echo "Found 1 microphone"
        listCard $micCards
      fi
      ;;
    *)                                     # more than one mic found
      if [ "$actionType" = record ]; then 
        if [ "$cardToUse" = default ]; then 
          # Automatically select the best microphone
          cardToUse=$(findBestMicrophone "$micCards")
          if [ -z "$cardToUse" ]; then
            echo "Uh-oh! Could not find a suitable microphone"
            echo "Found microphones: $micCards"
            usage
          fi
          echo "Found $micCount microphones - automatically selecting card $cardToUse as best option"
        fi
        recordCard $cardToUse
      else                                 # assume list
        echo "Found $micCount microphones"
        local nextCard
        for nextCard in $micCards; do
          listCard $nextCard
        done      
      fi
      ;;
  esac
 }                                         # performAction()

#+--------------------------------------------------------------------------+
# Global variables"
actionType="record"                        # "record" or "list"
cardToUse="default"                        # "default" or card number
numSecs="5"                                # number of seconds to record
verbose=1                                  # verbosity "1" or "2"
flags=""                                   # flags to pass on

# main()
parseArgs $@                               # parse arguments
performAction                              # perform the test 
retVal=$?                                  # get return code
if [ $retVal != 0 ]; then
  exit $retVal
elif [ ! -x /usr/local/sbin/testplay ]; then
  echo "ERROR: did not find executable file /usr/local/sbin/testplay" ];
  exit 2
fi
echo "Calling testplay to play back the recording ..."
/usr/local/sbin/testplay $flags
exit $?

